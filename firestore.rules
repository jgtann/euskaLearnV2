/**
 * # Firestore Security Rules: Euskal Sustatzailea App
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model. Each user has complete control over their own data, which is stored within a path dedicated to their user ID (`/users/{userId}`). This prevents users from accessing or modifying each other's private information, such as profiles and learning progress. Public content is stored in a separate top-level collection, accessible to all but modifiable only from a trusted server environment.
 *
 * ## Data Structure
 * - `/users/{userId}`: Contains a user's public profile and serves as the root for their private data.
 * - `/users/{userId}/user_learning_items/{userLearningItemId}`: A subcollection storing a user's specific progress and review data for each learning item. Access is inherited from the parent user document.
 * - `/learning_items/{learningItemId}`: A top-level collection containing all educational content. This data is intended to be publicly readable by everyone.
 *
 * ## Key Security Decisions
 * - **Strict User Scoping**: All user-specific data is nested under `/users/{userId}`, and rules ensure only the matching authenticated user can perform any action on that data.
 * - **No User Enumeration**: Listing the top-level `/users` collection is explicitly disallowed to protect user privacy.
 * - **Public Read-Only Content**: The `/learning_items` collection is readable by any user (authenticated or not) but is locked down against all client-side writes to maintain data integrity. It is assumed this content is managed via the Firebase Admin SDK.
 * - **Default Deny**: Any path not explicitly defined in these rules is inaccessible.
 *
 * ## Denormalization for Authorization
 * This ruleset primarily uses path-based authorization. The user's UID in the document path (e.g., `{userId}`) is the primary mechanism for securing access. For subcollections like `user_learning_items`, we also enforce relational integrity by requiring a `userId` field within the document data itself, ensuring a permanent and immutable link back to its owner.
 *
 * ## Structural Segregation
 * The ruleset leverages separate collections for private and public data. Private user progress (`/users/{userId}/user_learning_items`) is structurally separate from public learning content (`/learning_items`). This is a secure and performant pattern that simplifies list operations and prevents accidental data exposure.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the primary function for checking document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the document being updated or deleted already exists
     * and the requesting user is the owner.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * [CREATE] Validates that the incoming document's 'id' field matches
     * the user's auth UID. Enforces relational integrity.
     */
    function incomingUserDataIsValid(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * [UPDATE] Validates that the 'id' field of a user document is immutable.
     * This prevents re-assigning a user profile to another user.
     */
    function userIdIsImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * [CREATE] Validates that the incoming document's 'userId' field matches
     * the userId from the path. Enforces relational integrity for subcollections.
     */
    function incomingDataHasValidOwner(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * [UPDATE] Validates that the 'userId' field of a subcollection document
     * is immutable.
     */
    function ownerIsImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }


    // =====================================================================
    // Collection Rules
    // =====================================================================

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow (create) A new user creating their own profile document.
     * @allow (get, update, delete) A signed-in user accessing their own profile.
     * @deny (get) A user trying to fetch another user's profile.
     * @deny (list) Any user trying to list all users in the collection.
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && incomingUserDataIsValid(userId);
      allow update: if isExistingOwner(userId) && userIdIsImmutable();
      allow delete: if isExistingOwner(userId);

      /**
       * @description Manages a user's personal learning progress and SRS data.
       * @path /users/{userId}/user_learning_items/{userLearningItemId}
       * @allow (create, get, list, update, delete) A user managing items in their own learning list.
       * @deny (get) A user trying to see another user's learning progress.
       * @principle Enforces document ownership based on the URL path and validates relational integrity.
       */
      match /user_learning_items/{userLearningItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && incomingDataHasValidOwner(userId);
        allow update: if isExistingOwner(userId) && ownerIsImmutable();
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Manages public, read-only learning items.
     * @path /learning_items/{learningItemId}
     * @allow (get, list) Any user (signed-in or anonymous) can read or list learning items.
     * @deny (create, update, delete) Any client-side attempt to modify learning items is blocked.
     * @principle Provides public read access to content while protecting data integrity by disallowing client writes.
     */
    match /learning_items/{learningItemId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}